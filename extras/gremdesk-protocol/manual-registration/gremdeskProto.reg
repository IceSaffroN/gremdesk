Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\gremdesk]
@="URL:GremDesk Protocol"
"URL Protocol"=""

[HKEY_CLASSES_ROOT\gremdesk\shell]

[HKEY_CLASSES_ROOT\gremdesk\shell\open]

[HKEY_CLASSES_ROOT\gremdesk\shell\open\command]
@="\"C:\\Gremster\\Gremdesk\\extras\\gremdesk-protocol\\GremDeskProto.vbs\" \"%1\""
